# DeepSeek API — used by both local harness runner (Dev 1) and cloud baseline runner (Dev 2)
DEEPSEEK_API_KEY=

# Gemini / GCP — used by cloud judge and test generator (Dev 2)
GEMINI_API_KEY=

# Cloud server base URL — set to mock server locally, real server in prod
ANTIGRAVITY_BASE_URL=http://localhost:8000

# Set to any non-empty value to render from a local cached report (no network)
TEMPER_OFFLINE=

# DeepSeek model to use — must be identical between harness runner and baseline runner
DEEPSEEK_MODEL=deepseek-chat
